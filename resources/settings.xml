<?xml version="1.0" encoding="utf-8"?>
<settings>
  <category label="Credentials">
    <setting id="username" type="text" label="Username" default="" />
    <setting id="password" type="text" label="Password" default="" />
  </category>
  <category label="Account">
    <setting id="profile_id" type="text" label="Active profile ID" default="" />
    <setting id="profile_name" type="text" label="Active profile name" default="" />
    <setting id="manage_profiles_button" type="button" label="Manage profiles..." default="" onClick="RunPlugin(plugin://plugin.video.nlziet/?mode=profiles)" />
    <setting id="apply_profile_button" type="button" label="Apply profile ID" default="" onClick="RunPlugin(plugin://plugin.video.nlziet/?mode=apply_profile)" />
  </category>
  <category label="Advanced">
    <setting id="api_base_url" type="text" label="API base URL (optional)" default="https://api.nlziet.nl" />
  </category>
  <category label="Playback">
    <setting id="subtitles_default" type="bool" label="Enable subtitles by default" default="false" />
  </category>
  <category label="Debug">
    <setting id="debug_http" type="bool" label="Enable HTTP debug logging" default="false" />
  </category>
</settings>
