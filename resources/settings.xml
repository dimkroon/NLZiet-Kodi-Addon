<?xml version="1.0" encoding="utf-8"?>
<settings>
  <category label="Credentials">
    <setting id="username" type="text" label="Email" default="" />
    <setting id="password" type="text" label="Password" default="" />
  </category>
  <category label="Account">
    <setting id="subscription_name" type="text" label="Subscription" default="" enabled="false" />
    <setting id="subscription_expires" type="text" label="Subscription expires" default="" enabled="false" />
    <setting id="max_devices" type="text" label="Max devices" default="" enabled="false" />
    <setting id="logout_button" type="action" label="Logout and clear local data" action="RunPlugin(plugin://plugin.video.nlziet/?mode=logout_confirm)" />  </category>
  <category label="Profiles">
    <setting id="profile_id" type="text" label="Active profile ID" default="" enabled="false" />
    <setting id="profile_name" type="text" label="Active profile name" default="" enabled="false" />
  </category>
  <category label="Advanced">
    <setting id="api_base_url" type="text" label="API base URL (optional)" default="https://api.nlziet.nl" />
  </category>
  <category label="Playback">
    <setting id="subtitles_default" type="bool" label="Enable subtitles by default" default="false" />
  </category>
  <category label="Debug">
    <setting id="debug_http" type="bool" label="Enable HTTP debug logging" default="false" />
  </category>
</settings>
